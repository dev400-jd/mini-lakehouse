{
  "data_asset_type": null,
  "expectation_suite_name": "curated_esg_emissions_suite",
  "expectations": [
    {
      "expectation_type": "expect_table_row_count_to_be_between",
      "kwargs": {
        "min_value": 100,
        "max_value": 200
      },
      "meta": {
        "description": "Curated muss mindestens 100 und maximal 200 Records haben (Plausibilitaetsbereich fuer Demo-Daten)"
      }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "isin"
      },
      "meta": {
        "description": "ISIN darf in Curated nicht null sein (NULL-ISINs wurden in AP-12 gefiltert)"
      }
    },
    {
      "expectation_type": "expect_column_value_lengths_to_equal",
      "kwargs": {
        "column": "isin",
        "value": 12
      },
      "meta": {
        "description": "ISIN muss exakt 12 Zeichen lang sein"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "source_system",
        "value_set": ["nzdpu", "cdp"]
      },
      "meta": {
        "description": "Nur die beiden bekannten Quellen sind erlaubt"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "scope_1_tco2e",
        "min_value": 0,
        "max_value": 100000000,
        "mostly": 0.95
      },
      "meta": {
        "description": "Scope 1 zwischen 0 und 100 Mio tCO2e in mindestens 95% der nicht-null Records (Plausibilitaetsbereich fuer DAX-Konzerne)"
      }
    },
    {
      "expectation_type": "expect_compound_columns_to_be_unique",
      "kwargs": {
        "column_list": ["isin", "reporting_year", "source_system"]
      },
      "meta": {
        "description": "Composite-Eindeutigkeit aus Curated-Design"
      }
    }
  ],
  "ge_cloud_id": null,
  "meta": {
    "great_expectations_version": "0.18.8"
  }
}
