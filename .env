# =============================================================================
# mini-lakehouse — Zentrale Konfiguration
# Single Source of Truth: Docker Compose und Skripte referenzieren nur diese Datei.
# =============================================================================


# === Image-Versionen ===
# Nessie 0.99.0 ist die mit Iceberg 1.7.1 getestete und freigegebene Kombination.
# apache/spark-py wurde nach 3.4.0 aufgegeben — Nachfolger ist apache/spark:VERSION-python3.
SPARK_VERSION=3.5.8
ICEBERG_VERSION=1.7.1
NESSIE_VERSION=0.99.0
TRINO_VERSION=468
MINIO_VERSION=RELEASE.2024-12-18T13-15-44Z
POSTGRES_VERSION=16
JUPYTER_VERSION=spark-3.5.3


# === MinIO (Objektspeicher / S3-kompatibler Layer) ===
MINIO_ROOT_USER=lakehouse
MINIO_ROOT_PASSWORD=lakehouse123
MINIO_ENDPOINT=http://minio:9000
MINIO_CONSOLE_PORT=9001
MINIO_API_PORT=9000


# === S3-Bucket-Namen ===
# Definiert die logischen Zonen der Datenpipeline (Medallion-Architektur).
S3_BUCKET_RAW=raw
S3_BUCKET_STAGING=staging
S3_BUCKET_CURATED=curated
S3_BUCKET_TRUSTED=trusted
S3_BUCKET_WAREHOUSE=warehouse


# === Nessie (Iceberg-Katalog mit Git-ähnlicher Versionierung) ===
NESSIE_PORT=19120
NESSIE_DB=nessie


# === PostgreSQL (Metastore-Backend für Nessie) ===
POSTGRES_USER=lakehouse
POSTGRES_PASSWORD=lakehouse123
POSTGRES_PORT=5432


# === Trino (Verteilte SQL-Abfrage-Engine) ===
TRINO_PORT=8080


# === CloudBeaver (Web-basierter SQL-Editor) ===
CLOUDBEAVER_PORT=8978


# === Jupyter (Interaktives Notebook-Environment) ===
JUPYTER_PORT=8888
JUPYTER_TOKEN=lakehouse


# === Spark (Verteilte Datenverarbeitung) ===
SPARK_MASTER_PORT=7077
SPARK_MASTER_WEBUI_PORT=8081


# === Dagster (Orchestrierung) ===
DAGSTER_DB=dagster


# === Python ===
PYTHON_VERSION=3.12
